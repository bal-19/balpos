NODE_ENV=development
PORT=4000

# Prisma / Supabase PostgreSQL — DATABASE_URL lewat connection pooler,
# DIRECT_URL koneksi langsung (dipakai saat `prisma migrate`).
DATABASE_URL=postgresql://user:password@localhost:5432/restaurant_pos?schema=public
DIRECT_URL=postgresql://user:password@localhost:5432/restaurant_pos?schema=public

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_STORAGE_BUCKET=restaurant-pos

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# Auth (JWT)
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Xendit Payment
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

# Google Gemini (AI Analytics)
GOOGLE_GEMINI_API_KEY=

# Google TTS (Voice Announcement)
GOOGLE_TTS_CREDENTIALS_JSON=

# CORS — daftar origin frontend, pisahkan dengan koma
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176
