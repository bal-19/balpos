generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrderType {
  DINE_IN
  TAKE_AWAY
  ORDER_ONLINE
}

enum OrderStatus {
  OPEN
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  QRIS
  DEBIT_CREDIT
  E_WALLET
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum KitchenItemStatus {
  NEW
  PREPARING
  READY
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  RECEIVED
  CANCELLED
}

enum PromotionType {
  VOUCHER
  DISCOUNT
  HAPPY_HOUR
  BUY_X_GET_Y
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

enum PointHistoryType {
  EARN
  REDEEM
  ADJUSTMENT
}

enum ReportType {
  SALES_SUMMARY
  ITEMS_PERFORMANCE
  TRANSACTIONS
}

enum ExportFileType {
  PDF
  EXCEL
}

enum ExportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AiInsightType {
  BEST_SELLING_MENU
  BUSIEST_HOURS
  RESTOCK_PREDICTION
  DECLINING_PRODUCTS
  SALES_SUMMARY
  BUSINESS_IMPROVEMENT
}

enum AiInsightSource {
  GEMINI
  LOCAL
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum NotificationType {
  ORDER_CREATED
  ORDER_READY
  LOW_STOCK
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outlets Outlet[]
  roles   Role[]
  users   User[]

  @@map("tenants")
}

model Outlet {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users           User[]
  setting         StoreSetting?
  categories      Category[]
  products        Product[]
  tables          Table[]
  orders          Order[]
  stockItems      StockItem[]
  stockMovements  StockMovement[]
  recipes         Recipe[]
  suppliers       Supplier[]
  purchaseOrders  PurchaseOrder[]
  customers       Customer[]
  membershipTiers MembershipTier[]
  promotions      Promotion[]
  reservations    Reservation[]
  auditLogs        AuditLog[]
  aiInsights       AiInsight[]
  reportExportJobs ReportExportJob[]
  shifts           Shift[]
  notifications    Notification[]

  @@index([tenantId])
  @@map("outlets")
}

model Role {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  name      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]
  permissions RolePermission[]

  @@unique([tenantId, code])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  module      String
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  outletId     String
  roleId       String
  name         String
  email        String    @unique
  passwordHash String
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)
  role   Role    @relation(fields: [roleId], references: [id])
  orders Order[] @relation("OrderCashier")
  shiftsOpened Shift[] @relation("ShiftOpenedBy")
  shiftsClosed Shift[] @relation("ShiftClosedBy")

  @@index([outletId])
  @@index([roleId])
  @@map("users")
}

model StoreSetting {
  id                   String   @id @default(cuid())
  outletId             String   @unique
  storeName            String
  logoUrl              String?
  primaryColor         String   @default("#2C4A3B")
  taxPercent           Decimal  @default(0) @db.Decimal(5, 2)
  serviceChargePercent Decimal  @default(0) @db.Decimal(5, 2)
  currency             String   @default("IDR")
  address              String?
  phone                String?
  receiptFooterNote    String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@map("store_settings")
}

model Category {
  id        String   @id @default(cuid())
  outletId  String
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outlet   Outlet    @relation(fields: [outletId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([outletId, name])
  @@index([outletId])
  @@map("categories")
}

model Product {
  id          String    @id @default(cuid())
  outletId    String
  categoryId  String
  name        String
  description String?
  price       Decimal   @db.Decimal(12, 2)
  imageUrl    String?
  isAvailable Boolean   @default(true)
  sortOrder   Int       @default(0)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  outlet     Outlet      @relation(fields: [outletId], references: [id], onDelete: Cascade)
  category   Category    @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  recipe     Recipe?

  @@index([outletId])
  @@index([categoryId])
  @@map("products")
}

model Table {
  id        String      @id @default(cuid())
  outletId  String
  name      String
  capacity  Int?
  isActive  Boolean     @default(true)
  status    TableStatus @default(AVAILABLE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  outlet       Outlet        @relation(fields: [outletId], references: [id], onDelete: Cascade)
  orders       Order[]
  reservations Reservation[]

  @@unique([outletId, name])
  @@map("tables")
}

model Order {
  id                  String      @id @default(cuid())
  outletId            String
  orderNumber         String
  orderType           OrderType
  status              OrderStatus @default(OPEN)
  tableId             String?
  customerId          String?
  customerName        String?
  cashierId           String?
  subtotal            Decimal     @db.Decimal(12, 2)
  taxAmount           Decimal     @default(0) @db.Decimal(12, 2)
  serviceChargeAmount Decimal     @default(0) @db.Decimal(12, 2)
  discountAmount      Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount         Decimal     @db.Decimal(12, 2)
  notes               String?
  completedAt         DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  shiftId             String?

  outlet     Outlet           @relation(fields: [outletId], references: [id], onDelete: Cascade)
  table      Table?           @relation(fields: [tableId], references: [id])
  customer   Customer?        @relation(fields: [customerId], references: [id])
  cashier    User?            @relation("OrderCashier", fields: [cashierId], references: [id])
  shift      Shift?           @relation(fields: [shiftId], references: [id])
  items      OrderItem[]
  payments   Payment[]
  promotions OrderPromotion[]

  @@unique([outletId, orderNumber])
  @@index([outletId, createdAt])
  @@index([shiftId])
  @@map("orders")
}

model OrderItem {
  id                  String            @id @default(cuid())
  orderId             String
  productId           String
  productNameSnapshot String
  unitPrice           Decimal           @db.Decimal(12, 2)
  quantity            Int
  notes               String?
  subtotal            Decimal           @db.Decimal(12, 2)
  kitchenStatus       KitchenItemStatus @default(NEW)
  createdAt           DateTime          @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([orderId, kitchenStatus])
  @@map("order_items")
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(12, 2)
  referenceNumber String?
  paymentUrl      String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("payments")
}

model StockItem {
  id                String   @id @default(cuid())
  outletId          String
  name              String
  unit              String
  currentStock      Decimal  @default(0) @db.Decimal(12, 3)
  minStockThreshold Decimal  @default(0) @db.Decimal(12, 3)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  outlet             Outlet              @relation(fields: [outletId], references: [id], onDelete: Cascade)
  movements          StockMovement[]
  recipeIngredients  RecipeIngredient[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([outletId, name])
  @@index([outletId])
  @@map("stock_items")
}

model StockMovement {
  id            String            @id @default(cuid())
  outletId      String
  stockItemId   String
  type          StockMovementType
  quantity      Decimal           @db.Decimal(12, 3)
  note          String?
  referenceType String?
  referenceId   String?
  createdAt     DateTime          @default(now())

  outlet    Outlet    @relation(fields: [outletId], references: [id], onDelete: Cascade)
  stockItem StockItem @relation(fields: [stockItemId], references: [id])

  @@index([outletId])
  @@index([stockItemId])
  @@map("stock_movements")
}

model Recipe {
  id        String   @id @default(cuid())
  productId String   @unique
  outletId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product     Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  outlet      Outlet             @relation(fields: [outletId], references: [id], onDelete: Cascade)
  ingredients RecipeIngredient[]

  @@map("recipes")
}

model RecipeIngredient {
  id          String  @id @default(cuid())
  recipeId    String
  stockItemId String
  quantity    Decimal @db.Decimal(12, 3)

  recipe    Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  stockItem StockItem @relation(fields: [stockItemId], references: [id])

  @@unique([recipeId, stockItemId])
  @@map("recipe_ingredients")
}

model Supplier {
  id        String   @id @default(cuid())
  outletId  String
  name      String
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outlet         Outlet          @relation(fields: [outletId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@index([outletId])
  @@map("suppliers")
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  outletId    String
  supplierId  String
  orderNumber String
  status      PurchaseOrderStatus @default(DRAFT)
  totalAmount Decimal             @default(0) @db.Decimal(12, 2)
  notes       String?
  receivedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  outlet   Outlet              @relation(fields: [outletId], references: [id], onDelete: Cascade)
  supplier Supplier            @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]

  @@unique([outletId, orderNumber])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  stockItemId     String
  quantity        Decimal @db.Decimal(12, 3)
  unitCost        Decimal @db.Decimal(12, 2)
  subtotal        Decimal @db.Decimal(12, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  stockItem     StockItem     @relation(fields: [stockItemId], references: [id])

  @@map("purchase_order_items")
}

model Customer {
  id               String    @id @default(cuid())
  outletId         String
  name             String
  phone            String?
  email            String?
  membershipTierId String?
  pointBalance     Int       @default(0)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  outlet         Outlet          @relation(fields: [outletId], references: [id], onDelete: Cascade)
  membershipTier MembershipTier? @relation(fields: [membershipTierId], references: [id])
  orders         Order[]
  pointHistories PointHistory[]
  reservations   Reservation[]

  @@index([outletId])
  @@map("customers")
}

model MembershipTier {
  id              String   @id @default(cuid())
  outletId        String
  name            String
  minPoint        Int      @default(0)
  discountPercent Decimal  @default(0) @db.Decimal(5, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  outlet    Outlet     @relation(fields: [outletId], references: [id], onDelete: Cascade)
  customers Customer[]

  @@unique([outletId, name])
  @@index([outletId])
  @@map("membership_tiers")
}

model PointHistory {
  id         String           @id @default(cuid())
  customerId String
  type       PointHistoryType
  points     Int
  note       String?
  orderId    String?
  createdAt  DateTime         @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("point_histories")
}

model Promotion {
  id            String        @id @default(cuid())
  outletId      String
  type          PromotionType
  code          String?
  name          String
  discountType  DiscountType
  discountValue Decimal       @db.Decimal(12, 2)
  minPurchase   Decimal       @default(0) @db.Decimal(12, 2)
  buyProductId  String?
  buyQuantity   Int?
  getProductId  String?
  getQuantity   Int?
  startAt       DateTime?
  endAt         DateTime?
  startTime     String?
  endTime       String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  outlet      Outlet           @relation(fields: [outletId], references: [id], onDelete: Cascade)
  orderUsages OrderPromotion[]

  @@unique([outletId, code])
  @@index([outletId])
  @@map("promotions")
}

model OrderPromotion {
  id             String   @id @default(cuid())
  orderId        String
  promotionId    String
  discountAmount Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  promotion Promotion @relation(fields: [promotionId], references: [id])

  @@unique([orderId, promotionId])
  @@map("order_promotions")
}

model Reservation {
  id            String            @id @default(cuid())
  outletId      String
  tableId       String
  customerId    String?
  customerName  String
  customerPhone String?
  partySize     Int
  reservedAt    DateTime
  status        ReservationStatus @default(PENDING)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  outlet   Outlet    @relation(fields: [outletId], references: [id], onDelete: Cascade)
  table    Table     @relation(fields: [tableId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([outletId])
  @@index([tableId])
  @@map("reservations")
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  outletId    String
  userId      String
  userName    String
  method      String
  path        String
  statusCode  Int
  requestBody Json?
  createdAt   DateTime @default(now())

  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId, createdAt])
  @@index([userId])
  @@map("audit_logs")
}

model AiInsight {
  id          String          @id @default(cuid())
  outletId    String
  type        AiInsightType
  source      AiInsightSource
  periodFrom  DateTime?
  periodTo    DateTime?
  content     String          @db.Text
  metadata    Json?
  requestedBy String
  createdAt   DateTime        @default(now())

  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId, type, createdAt])
  @@map("ai_insights")
}

model ReportExportJob {
  id            String          @id @default(cuid())
  outletId      String
  reportType    ReportType
  fileType      ExportFileType
  status        ExportJobStatus @default(PENDING)
  periodFrom    DateTime
  periodTo      DateTime
  fileUrl       String?
  failureReason String?
  requestedBy   String
  createdAt     DateTime        @default(now())
  completedAt   DateTime?

  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId, createdAt])
  @@map("report_export_jobs")
}

model Shift {
  id              String      @id @default(cuid())
  outletId        String
  openedBy        String
  closedBy        String?
  openingBalance  Decimal     @db.Decimal(12, 2)
  closingBalance  Decimal?    @db.Decimal(12, 2)
  expectedBalance Decimal?    @db.Decimal(12, 2)
  variance        Decimal?    @db.Decimal(12, 2)
  status          ShiftStatus @default(OPEN)
  notes           String?
  openedAt        DateTime    @default(now())
  closedAt        DateTime?

  outlet       Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)
  openedByUser User    @relation("ShiftOpenedBy", fields: [openedBy], references: [id])
  closedByUser User?   @relation("ShiftClosedBy", fields: [closedBy], references: [id])
  orders       Order[]

  @@index([outletId, status])
  @@map("shifts")
}

model Notification {
  id            String           @id @default(cuid())
  outletId      String
  type          NotificationType
  title         String
  message       String
  referenceType String?
  referenceId   String?
  isRead        Boolean          @default(false)
  createdAt     DateTime         @default(now())

  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([outletId, isRead, createdAt])
  @@map("notifications")
}
