# Root env — dipakai oleh docker-compose.yml untuk port mapping antar service.
# Env spesifik per app (secrets, koneksi eksternal) ada di apps/<app>/.env.example masing-masing.

NODE_ENV=development

API_PORT=4000
DASHBOARD_PORT=5173
KITCHEN_DISPLAY_PORT=5174
CUSTOMER_DISPLAY_PORT=5175
ORDERING_PORT=5176

REDIS_PORT=6379
